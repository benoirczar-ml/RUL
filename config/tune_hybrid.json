{
  "data_dir": "RULdata/CMAPSSData",
  "fds": ["FD001", "FD002", "FD003", "FD004"],
  "grid": {
    "epochs": [12],
    "patience": [3],
    "sample_step": [1],
    "batch_size": [256],
    "device": ["cuda"],
    "num_workers": [2],
    "conv_channels": [96, 128],
    "kernel_size": [3, 5],
    "attention_heads": [4],
    "hidden_size": [96],
    "num_layers": [2],
    "dropout": [0.2],
    "num_fd_heads": [4],
    "loss_name": ["huber_asymmetric"],
    "huber_delta": [10.0],
    "late_error_weight": [0.35],
    "late_error_margin": [0.0],
    "emphasize_failure": [true],
    "failure_rul_threshold": [30],
    "failure_weight": [2.0],
    "learning_rate": [0.001],
    "weight_decay": [1e-05],
    "log_every_epoch": [true]
  }
}
