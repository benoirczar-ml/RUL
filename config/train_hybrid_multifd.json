{
  "data_dir": "RULdata/CMAPSSData",
  "fds": ["FD001", "FD002", "FD003", "FD004"],
  "max_rul": 125,
  "val_fraction": 0.2,
  "val_strategy": "truncation",
  "val_min_prefix": 20,
  "seed": 42,
  "seq_len": 30,
  "sample_step": 1,
  "conv_channels": 128,
  "kernel_size": 5,
  "attention_heads": 4,
  "hidden_size": 96,
  "num_layers": 2,
  "dropout": 0.2,
  "num_fd_heads": 4,
  "loss_name": "huber_asymmetric",
  "huber_delta": 10.0,
  "late_error_weight": 0.35,
  "late_error_margin": 0.0,
  "emphasize_failure": true,
  "failure_rul_threshold": 30,
  "failure_weight": 2.0,
  "sampling_strategy": "balanced_fd_failure",
  "fd_balance_power": 1.0,
  "warmup_mse_epochs": 2,
  "learning_rate": 0.001,
  "weight_decay": 1e-05,
  "epochs": 10,
  "batch_size": 256,
  "patience": 3,
  "device": "cuda",
  "num_workers": 2,
  "pin_memory": true,
  "non_blocking": true,
  "use_amp": true,
  "enable_tf32": true,
  "cudnn_benchmark": true,
  "log_every_epoch": true
}
